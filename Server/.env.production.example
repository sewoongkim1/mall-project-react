# ================================================
# StyleAI Server — 환경변수 (프로덕션)
# Render 대시보드 Environment Variables에 설정
# ================================================

NODE_ENV=production
PORT=10000

# MongoDB Atlas 연결 문자열
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/styleai?retryWrites=true&w=majority

# JWT (반드시 강력한 시크릿으로 변경)
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 토스페이먼츠
TOSSPAYMENTS_SECRET_KEY=

# 클라이언트 URL (Vercel 배포 URL)
CLIENT_URL=https://styleai.vercel.app
