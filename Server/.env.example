# ================================================
# StyleAI Server — 환경변수
# .env.example 복사 후 .env 로 저장하고 값 입력
# ================================================

# 서버 포트
PORT=5000
NODE_ENV=development

# MongoDB (https://cloud.mongodb.com → 클러스터 연결)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/styleai?retryWrites=true&w=majority

# JWT 시크릿 (랜덤 문자열 32자 이상 권장)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Cloudinary (이미지 업로드, https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# 토스페이먼츠 결제 (https://developers.tosspayments.com)
TOSSPAYMENTS_SECRET_KEY=test_sk_...

# 클라이언트 URL (CORS 허용)
CLIENT_URL=http://localhost:5173
