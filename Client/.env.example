# API 서버 주소 (개발: vite proxy 사용, 배포: 실서버 주소)
VITE_API_URL=http://localhost:5000/api

# 토스페이먼츠 클라이언트 키
VITE_TOSSPAYMENTS_CLIENT_KEY=test_ck_...

# 앱 정보
VITE_APP_NAME=StyleAI
